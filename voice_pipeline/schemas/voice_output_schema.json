{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MSME-Graph Voice Pipeline Output",
  "description": "Output schema for the STT/TTS voice pipeline module. Version 1.0.0.",
  "type": "object",
  "required": [
    "module",
    "schema_version",
    "session_id",
    "timestamp_utc",
    "processing_time_ms",
    "audio_metadata",
    "transcript",
    "extracted_entities",
    "confidence_scores",
    "nsic_gate3_signals",
    "ondc_hints",
    "merge_ready",
    "missing_critical_fields",
    "conversation_complete",
    "partial_data_flag"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "voice_stt_tts"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "processing_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "audio_metadata": {
      "type": "object",
      "required": [
        "duration_seconds",
        "language_detected",
        "language_confidence",
        "audio_quality_score",
        "chunks_processed",
        "rounds_of_conversation"
      ],
      "properties": {
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "language_detected": {
          "type": "string"
        },
        "language_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "audio_quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "chunks_processed": {
          "type": "integer",
          "minimum": 0
        },
        "rounds_of_conversation": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "transcript": {
      "type": "object",
      "required": [
        "raw_transcript",
        "cleaned_transcript",
        "language",
        "romanised_transcript"
      ],
      "properties": {
        "raw_transcript": {
          "type": "string"
        },
        "cleaned_transcript": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "romanised_transcript": {
          "type": "string"
        }
      }
    },
    "extracted_entities": {
      "type": "object",
      "required": [
        "enterprise_name",
        "product_descriptions",
        "raw_materials_mentioned",
        "manufacturing_process_keywords",
        "buyer_types_mentioned",
        "buyer_geographies_mentioned",
        "production_scale_mentioned",
        "years_in_business",
        "employees_count",
        "existing_online_presence",
        "export_signal",
        "selling_channels",
        "annual_turnover",
        "daily_production_capacity",
        "factory_area_size",
        "major_machinery_used"
      ],
      "properties": {
        "enterprise_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "product_descriptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "raw_materials_mentioned": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manufacturing_process_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "daily_production_capacity": {
          "type": [
            "string",
            "null"
          ]
        },
        "factory_area_size": {
          "type": [
            "string",
            "null"
          ]
        },
        "major_machinery_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "buyer_types_mentioned": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "wholesale",
              "retail",
              "government",
              "export",
              "direct_consumer",
              "other_businesses"
            ]
          }
        },
        "buyer_geographies_mentioned": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "production_scale_mentioned": {
          "type": [
            "string",
            "null"
          ]
        },
        "years_in_business": {
          "type": [
            "integer",
            "null"
          ]
        },
        "employees_count": {
          "type": [
            "integer",
            "null"
          ]
        },
        "existing_online_presence": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "export_signal": {
          "type": "boolean"
        },
        "selling_channels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "annual_turnover": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "confidence_scores": {
      "type": "object",
      "properties": {
        "enterprise_name": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "product_descriptions": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "raw_materials_mentioned": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "manufacturing_process_keywords": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "buyer_types_mentioned": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "buyer_geographies_mentioned": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "production_scale_mentioned": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "overall_extraction_confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "nsic_gate3_signals": {
      "type": "object",
      "required": [
        "manufacturing_evidence_found",
        "trading_evidence_found",
        "process_keywords_count",
        "raw_material_signals_count",
        "voice_mfg_confidence_score",
        "flag_for_human_review",
        "flag_reason"
      ],
      "properties": {
        "manufacturing_evidence_found": {
          "type": "boolean"
        },
        "trading_evidence_found": {
          "type": "boolean"
        },
        "process_keywords_count": {
          "type": "integer",
          "minimum": 0
        },
        "raw_material_signals_count": {
          "type": "integer",
          "minimum": 0
        },
        "voice_mfg_confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "flag_for_human_review": {
          "type": "boolean"
        },
        "flag_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ondc_hints": {
      "type": "object",
      "required": [
        "likely_sector",
        "likely_ondc_domain",
        "b2b_signal",
        "b2c_signal",
        "export_signal"
      ],
      "properties": {
        "likely_sector": {
          "type": [
            "string",
            "null"
          ]
        },
        "likely_ondc_domain": {
          "type": [
            "string",
            "null"
          ]
        },
        "b2b_signal": {
          "type": "boolean"
        },
        "b2c_signal": {
          "type": "boolean"
        },
        "export_signal": {
          "type": "boolean"
        }
      }
    },
    "merge_ready": {
      "type": "boolean"
    },
    "missing_critical_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conversation_complete": {
      "type": "boolean"
    },
    "partial_data_flag": {
      "type": "boolean"
    }
  }
}