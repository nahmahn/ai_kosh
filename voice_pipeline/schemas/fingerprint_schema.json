{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Verified Capability Fingerprint",
    "description": "Final merged output schema combining voice + OCR data. Version 1.0.0.",
    "type": "object",
    "required": [
        "schema_version",
        "fingerprint_id",
        "generated_at",
        "data_sources",
        "overall_data_completeness",
        "identity",
        "capability",
        "commercial_profile",
        "scale",
        "nsic_preclearance",
        "ondc_mapping"
    ],
    "properties": {
        "schema_version": {
            "type": "string",
            "const": "1.0.0"
        },
        "fingerprint_id": {
            "type": "string",
            "format": "uuid"
        },
        "generated_at": {
            "type": "string",
            "format": "date-time"
        },
        "data_sources": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "voice",
                    "udyam",
                    "gstr1"
                ]
            }
        },
        "overall_data_completeness": {
            "type": "string",
            "enum": [
                "HIGH",
                "MEDIUM",
                "LOW"
            ]
        },
        "identity": {
            "type": "object",
            "properties": {
                "enterprise_name": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "udyam_id": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "gstin": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "enterprise_class": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "major_activity": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "district": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "state": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "capability": {
            "type": "object",
            "properties": {
                "nic_codes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "hsn_codes_transacted": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "product_descriptions_raw": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "manufacturing_process_keywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "raw_materials_mentioned": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "commercial_profile": {
            "type": "object",
            "properties": {
                "b2b_ratio": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "b2c_ratio": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "export_signal": {
                    "type": "boolean"
                },
                "avg_invoice_value_inr": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "annual_turnover_inr": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "peak_months": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "buyer_geographies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "existing_online_presence": {
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "buyer_types": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "scale": {
            "type": "object",
            "properties": {
                "employees_count": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "years_in_business": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "production_scale_mentioned": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "nsic_preclearance": {
            "type": "object",
            "properties": {
                "udyam_api_valid": {
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "enterprise_class_eligible": {
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "major_activity_eligible": {
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "already_on_ondc": {
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "manufacturing_confidence_score": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "minimum": 0,
                    "maximum": 1
                },
                "overall_clearance": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "flags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ondc_mapping": {
            "type": "object",
            "properties": {
                "likely_ondc_domain": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "ondc_category_candidates": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "b2b_signal": {
                    "type": "boolean"
                },
                "b2c_signal": {
                    "type": "boolean"
                }
            }
        }
    }
}