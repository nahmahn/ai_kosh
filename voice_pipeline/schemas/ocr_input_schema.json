{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "OCR Document Extraction Output",
    "description": "Input schema for the OCR module output that this voice pipeline merges with. Version 1.0.0.",
    "type": "object",
    "required": [
        "module",
        "schema_version",
        "merge_ready"
    ],
    "properties": {
        "module": {
            "type": "string",
            "const": "ocr_document_extraction"
        },
        "schema_version": {
            "type": "string",
            "const": "1.0.0"
        },
        "udyam": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "udyam_id": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "enterprise_name": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "nic_2digit": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "nic_5digit": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "enterprise_class": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "major_activity": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "district": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "state": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "gstin_from_udyam": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "date_of_incorporation": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "social_category": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "extraction_confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "gstr1": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "gstin": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "hsn_codes_transacted": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "b2b_ratio": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "b2c_ratio": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "avg_invoice_value_inr": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "peak_months": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "buyer_gstins_states": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "annual_turnover_inr": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "manufacturing_confidence_score": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "nsic_preclearance": {
            "type": [
                "object",
                "null"
            ],
            "properties": {
                "manufacturing_confidence_score": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "minimum": 0,
                    "maximum": 1
                },
                "trading_pattern_detected": {
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "nsic_gate3_status": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "flag_reason": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "merge_ready": {
            "type": "boolean"
        },
        "documents_processed": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "documents_missing": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "partial_data_flag": {
            "type": "boolean"
        }
    }
}