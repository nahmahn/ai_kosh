{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "OCR Document Extraction Output",
    "description": "Input schema for the OCR module output that this voice pipeline merges with. Version 1.0.0.",
    "type": "object",
    "required": [
        "module",
        "schema_version",
        "udyam",
        "gstr1",
        "merge_ready"
    ],
    "properties": {
        "module": {
            "type": "string",
            "const": "ocr_document_extraction"
        },
        "schema_version": {
            "type": "string",
            "const": "1.0.0"
        },
        "udyam": {
            "type": "object",
            "properties": {
                "udyam_id": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "nic_codes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "enterprise_class": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "major_activity": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "district": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "state": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "gstr1": {
            "type": "object",
            "properties": {
                "gstin": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "hsn_codes_transacted": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "b2b_ratio": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "b2c_ratio": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "avg_invoice_value_inr": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "peak_months": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "buyer_gstins_states": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "annual_turnover_inr": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "manufacturing_confidence_score": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "merge_ready": {
            "type": "boolean"
        }
    }
}